<dialog id="vehicle_modal" class="modal">
  <div class="modal-box w-11/12 max-w-3xl bg-base-100 text-base-content">
    <form method="dialog">
      <button class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3">✕</button>
    </form>

    <div class="mb-6">
      <h3 class="text-2xl font-black">Add Vehicle</h3>
      <p class="mt-2 text-sm text-base-content/60">Create a new fleet asset and post it to <span class="font-semibold">/create-vehicle</span>.</p>
    </div>

    <form action="/create-vehicle" method="post" class="grid gap-4 md:grid-cols-2">
      <label class="form-control">
        <div class="label"><span class="label-text">Registration Number</span></div>
        <input name="registrationNumber" type="text" class="input input-bordered w-full bg-base-100" required />
      </label>

      <label class="form-control">
        <div class="label"><span class="label-text">Vehicle Name / Model</span></div>
        <input name="vehicleName" type="text" class="input input-bordered w-full bg-base-100" required />
      </label>

      <label class="form-control">
        <div class="label"><span class="label-text">Type</span></div>
        <input name="type" type="text" class="input input-bordered w-full bg-base-100" placeholder="Van, Truck, Mini..." required />
      </label>

      <label class="form-control">
        <div class="label"><span class="label-text">Status</span></div>
        <select name="status" class="select select-bordered w-full bg-base-100" required>
          <option value="Available">Available</option>
          <option value="On Trip">On Trip</option>
          <option value="In Shop">In Shop</option>
          <option value="Retired">Retired</option>
        </select>
      </label>

      <label class="form-control">
        <div class="label"><span class="label-text">Capacity</span></div>
        <input name="maximumLoadCapacity" type="text" class="input input-bordered w-full bg-base-100" placeholder="500 kg" />
      </label>

      <label class="form-control">
        <div class="label"><span class="label-text">Odometer</span></div>
        <input name="odometer" type="text" class="input input-bordered w-full bg-base-100" placeholder="74,000" />
      </label>

      <label class="form-control md:col-span-2">
        <div class="label"><span class="label-text">Acquisition Cost</span></div>
        <input name="acquisitionCost" type="text" class="input input-bordered w-full bg-base-100" placeholder="6,20,000" />
      </label>

      <div class="modal-action md:col-span-2">
        <button type="button" class="btn btn-ghost" onclick="document.getElementById('vehicle_modal').close()">Cancel</button>
        <button type="submit" class="btn btn-warning text-warning-content">Save Vehicle</button>
      </div>
    </form>
  </div>
</dialog>