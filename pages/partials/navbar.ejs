<header class="sticky top-0 z-50 border-b border-base-300 bg-base-100/80 backdrop-blur">
  <div class="navbar container mx-auto max-w-7xl px-6">
    <div class="navbar-start">
      <a class="btn btn-ghost text-xl font-black tracking-tight" href="/">TransitOps</a>
    </div>
    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 text-base-content/70">
        <li><a href="#overview" class="<%= active === 'home' ? 'active' : '' %>">Overview</a></li>
        <li><a href="#workflows">Workflows</a></li>
        <li><a href="#overview">Features</a></li>
      </ul>
    </div>
    <div class="navbar-end gap-2">
      <div id="navbarGuestActions" class="flex items-center gap-2">
        <a class="btn btn-ghost btn-sm hidden sm:inline-flex" href="/login">Login</a>
        <a class="btn btn-primary btn-sm" href="/register">Get started</a>
      </div>
      <div id="navbarAuthActions" class="hidden flex items-center gap-2">
        <button id="navbarLogoutButton" class="btn btn-error btn-sm" type="button">Logout</button>
      </div>
    </div>
  </div>
</header>

<script>
  (() => {
    const guestActions = document.getElementById('navbarGuestActions');
    const authActions = document.getElementById('navbarAuthActions');
    const logoutButton = document.getElementById('navbarLogoutButton');
    const token = localStorage.getItem('transitops_token');

    const setGuestState = () => {
      guestActions?.classList.remove('hidden');
      authActions?.classList.add('hidden');
    };

    const setAuthedState = () => {
      guestActions?.classList.add('hidden');
      authActions?.classList.remove('hidden');
    };

    const attachLogout = () => {
      logoutButton?.addEventListener('click', () => {
        localStorage.removeItem('transitops_token');
        localStorage.removeItem('transitops_user');
        window.location.href = '/login';
      });
    };

    if (!token) {
      setGuestState();
      return;
    }

    fetch('/api/auth/me', {
      headers: {
        Authorization: `Bearer ${token}`
      }
    })
      .then((response) => {
        if (!response.ok) {
          throw new Error('Invalid session');
        }

        return response.json();
      })
      .then(() => {
        setAuthedState();
        attachLogout();
      })
      .catch(() => {
        localStorage.removeItem('transitops_token');
        localStorage.removeItem('transitops_user');
        setGuestState();
      });
  })();
</script>
