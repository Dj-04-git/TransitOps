<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Drivers · TransitOps</title>
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/fleet.css" />
  <link rel="stylesheet" href="/css/drivers.css" />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
</head>
<body>

  <div class="dash-shell">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <svg class="brand-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="20" fill="rgba(232,56,95,0.12)"/>
          <path d="M9 24c3-9 8-13 11-13s8 4 11 13" stroke="#e8385f" stroke-width="2.4" stroke-linecap="round" fill="none"/>
          <circle cx="9" cy="24" r="2.6" fill="#e8385f"/>
          <circle cx="31" cy="24" r="2.6" fill="#e8385f"/>
          <circle cx="20" cy="11" r="2.6" fill="#101b30"/>
        </svg>
        <span class="brand-name">TransitOps</span>
      </div>

      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item">
          <i class="fa-solid fa-gauge"></i> Dashboard
        </a>
        <a href="/fleet" class="nav-item">
          <i class="fa-solid fa-truck"></i> Fleet
        </a>
        <a href="/drivers" class="nav-item active">
          <i class="fa-solid fa-id-card"></i> Drivers
        </a>
        <a href="/trips" class="nav-item">
          <i class="fa-solid fa-route"></i> Trips
        </a>
        <a href="/maintenance" class="nav-item">
          <i class="fa-solid fa-screwdriver-wrench"></i> Maintenance
        </a>
        <a href="/fuel-expenses" class="nav-item">
          <i class="fa-solid fa-gas-pump"></i> Fuel &amp; Expenses
        </a>
        <a href="/analytics" class="nav-item">
          <i class="fa-solid fa-chart-line"></i> Analytics
        </a>
        <a href="/settings" class="nav-item">
          <i class="fa-solid fa-gear"></i> Settings
        </a>
      </nav>
    </aside>

    <!-- Main -->
    <div class="dash-main">

      <header class="topbar">
        <div class="topbar-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search drivers…" id="driverSearch" />
        </div>

        <div class="topbar-right">
          <button class="icon-btn" title="Notifications">
            <i class="fa-regular fa-bell"></i>
          </button>
          <div class="user-block">
            <span class="user-name" id="userName">—</span>
            <span class="status-pill" id="connectionStatus">
              <span class="status-dot"></span> Connecting…
            </span>
          </div>
        </div>
      </header>

      <main class="dash-content">

        <div class="content-header content-header-row">
          <h1>Drivers &amp; Safety Profiles</h1>
          <button class="btn-primary" id="addDriverBtn">
            <i class="fa-solid fa-plus"></i> Add Driver
          </button>
        </div>

        <!-- Driver registry table — populated by loadDrivers() in drivers.js -->
        <section class="panel panel-fleet">
          <table class="vehicles-table drivers-table">
            <thead>
              <tr>
                <th>Driver</th>
                <th>License No.</th>
                <th>Category</th>
                <th>Expiry</th>
                <th>Contact</th>
                <th>Trip Compl.</th>
                <th>Safety</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="driversBody">
              <tr class="table-loading-row">
                <td colspan="9">Loading drivers…</td>
              </tr>
            </tbody>
          </table>
        </section>

        <div class="status-legend">
          <span class="legend-title">Toggle Status</span>
          <span class="driver-status available legend-pill">Available</span>
          <span class="driver-status on-trip legend-pill">On Trip</span>
          <span class="driver-status off-duty legend-pill">Off Duty</span>
          <span class="driver-status suspended legend-pill">Suspended</span>
        </div>

        <p class="table-note table-note-warning">
          Rule: Expired license or Suspended status — blocked from trip assignment.
        </p>

      </main>
    </div>
  </div>

  <!-- Add / Edit Driver Modal -->
  <div class="modal-overlay" id="driverModalOverlay">
    <div class="modal">
      <div class="modal-header">
        <h2 id="driverModalTitle">Add Driver</h2>
        <button class="icon-btn" id="closeDriverModal" title="Close">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form id="driverForm" class="modal-body">
        <input type="hidden" id="driverId" />

        <div class="form-row">
          <label for="driverName">Driver Name</label>
          <input type="text" id="driverName" required placeholder="e.g. Alex Mehta" />
        </div>

        <div class="form-row form-row-split">
          <div>
            <label for="licenseNo">License No.</label>
            <input type="text" id="licenseNo" required placeholder="e.g. DL-8823" />
          </div>
          <div>
            <label for="licenseCategory">Category</label>
            <select id="licenseCategory" required>
              <option value="LMV">LMV</option>
              <option value="HMV">HMV</option>
            </select>
          </div>
        </div>

        <div class="form-row form-row-split">
          <div>
            <label for="licenseExpiry">License Expiry</label>
            <input type="month" id="licenseExpiry" required />
          </div>
          <div>
            <label for="contact">Contact</label>
            <input type="text" id="contact" placeholder="e.g. 9876500000" />
          </div>
        </div>

        <div class="form-row form-row-split">
          <div>
            <label for="safetyStatus">Safety</label>
            <select id="safetyStatus" required>
              <option value="Available">Available</option>
              <option value="On Trip">On Trip</option>
              <option value="Off Duty">Off Duty</option>
              <option value="Suspended">Suspended</option>
            </select>
          </div>
          <div>
            <label for="driverStatus">Status</label>
            <select id="driverStatus" required>
              <option value="Available">Available</option>
              <option value="On Trip">On Trip</option>
              <option value="Off Duty">Off Duty</option>
              <option value="Suspended">Suspended</option>
            </select>
          </div>
        </div>

        <p class="form-error" id="driverFormError"></p>

        <div class="modal-footer">
          <button type="button" class="btn-secondary" id="cancelDriverModal">Cancel</button>
          <button type="submit" class="btn-primary" id="saveDriverBtn">Save Driver</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/drivers.js"></script>
</body>
</html>
