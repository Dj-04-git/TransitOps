<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard · TransitOps</title>
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
</head>
<body>

  <div class="dash-shell">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <svg class="brand-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="20" fill="rgba(232,56,95,0.12)"/>
          <path d="M9 24c3-9 8-13 11-13s8 4 11 13" stroke="#e8385f" stroke-width="2.4" stroke-linecap="round" fill="none"/>
          <circle cx="9" cy="24" r="2.6" fill="#e8385f"/>
          <circle cx="31" cy="24" r="2.6" fill="#e8385f"/>
          <circle cx="20" cy="11" r="2.6" fill="#101b30"/>
        </svg>
        <span class="brand-name">TransitOps</span>
      </div>

      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item active">
          <i class="fa-solid fa-gauge"></i> Dashboard
        </a>
        <a href="/fleet" class="nav-item">
          <i class="fa-solid fa-truck"></i> Fleet
        </a>
        <a href="/drivers" class="nav-item">
          <i class="fa-solid fa-id-card"></i> Drivers
        </a>
        <a href="/trips" class="nav-item">
          <i class="fa-solid fa-route"></i> Trips
        </a>
        <a href="/maintenance" class="nav-item">
          <i class="fa-solid fa-screwdriver-wrench"></i> Maintenance
        </a>
        <a href="/fuel-expenses" class="nav-item">
          <i class="fa-solid fa-gas-pump"></i> Fuel &amp; Expenses
        </a>
        <a href="/analytics" class="nav-item">
          <i class="fa-solid fa-chart-line"></i> Analytics
        </a>
        <a href="/settings" class="nav-item">
          <i class="fa-solid fa-gear"></i> Settings
        </a>
      </nav>
    </aside>

    <!-- Main -->
    <div class="dash-main">

      <header class="topbar">
        <div class="topbar-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search vehicles, drivers, trips…" id="globalSearch" />
        </div>

        <div class="topbar-right">
          <button class="icon-btn" title="Notifications">
            <i class="fa-regular fa-bell"></i>
          </button>
          <div class="user-block">
            <span class="user-name" id="userName">—</span>
            <span class="status-pill" id="connectionStatus">
              <span class="status-dot"></span> Connecting…
            </span>
          </div>
        </div>
      </header>

      <main class="dash-content">

        <div class="content-header">
          <h1>Dashboard</h1>
        </div>

        <div class="filters-row">
          <div class="filter-select">
            <label>Vehicle Type</label>
            <select id="filterVehicleType">
              <option value="all">All</option>
            </select>
          </div>
          <div class="filter-select">
            <label>Status</label>
            <select id="filterStatus">
              <option value="all">All</option>
            </select>
          </div>
          <div class="filter-select">
            <label>Region</label>
            <select id="filterRegion">
              <option value="all">All</option>
            </select>
          </div>
        </div>

        <!-- KPI stat cards — populated by loadKpis() in dashboard.js -->
        <section class="stat-cards" id="statCards" aria-live="polite">
          <div class="stat-skeleton"></div>
          <div class="stat-skeleton"></div>
          <div class="stat-skeleton"></div>
          <div class="stat-skeleton"></div>
          <div class="stat-skeleton"></div>
          <div class="stat-skeleton"></div>
          <div class="stat-skeleton"></div>
        </section>

        <section class="panels-row">

          <!-- Recent trips — populated by loadReports() in dashboard.js -->
          <div class="panel panel-trips">
            <div class="panel-header">
              <h2>Recent Trips</h2>
            </div>
            <table class="trips-table">
              <thead>
                <tr>
                  <th>Trip</th>
                  <th>Vehicle</th>
                  <th>Driver</th>
                  <th>Status</th>
                  <th>ETA</th>
                </tr>
              </thead>
              <tbody id="tripsBody">
                <tr class="table-loading-row">
                  <td colspan="5">Loading recent trips…</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Vehicle status breakdown — populated by loadAnalytics() in dashboard.js -->
          <div class="panel panel-status">
            <div class="panel-header">
              <h2>Vehicle Status</h2>
            </div>
            <div id="vehicleStatusBars" class="status-bars">
              <div class="status-loading">Loading fleet status…</div>
            </div>
          </div>

        </section>

      </main>
    </div>
  </div>

  <script src="/js/dashboard.js"></script>
</body>
</html>