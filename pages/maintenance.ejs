<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maintenance · TransitOps</title>
  <link rel="stylesheet" href="/css/dashboard.css" />
  <link rel="stylesheet" href="/css/fleet.css" />
  <link rel="stylesheet" href="/css/maintenance.css" />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
</head>
<body>

  <div class="dash-shell">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <svg class="brand-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="20" cy="20" r="20" fill="rgba(232,56,95,0.12)"/>
          <path d="M9 24c3-9 8-13 11-13s8 4 11 13" stroke="#e8385f" stroke-width="2.4" stroke-linecap="round" fill="none"/>
          <circle cx="9" cy="24" r="2.6" fill="#e8385f"/>
          <circle cx="31" cy="24" r="2.6" fill="#e8385f"/>
          <circle cx="20" cy="11" r="2.6" fill="#101b30"/>
        </svg>
        <span class="brand-name">TransitOps</span>
      </div>

      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item">
          <i class="fa-solid fa-gauge"></i> Dashboard
        </a>
        <a href="/fleet" class="nav-item">
          <i class="fa-solid fa-truck"></i> Fleet
        </a>
        <a href="/drivers" class="nav-item">
          <i class="fa-solid fa-id-card"></i> Drivers
        </a>
        <a href="/trips" class="nav-item">
          <i class="fa-solid fa-route"></i> Trips
        </a>
        <a href="/maintenance" class="nav-item active">
          <i class="fa-solid fa-screwdriver-wrench"></i> Maintenance
        </a>
        <a href="/fuel-expenses" class="nav-item">
          <i class="fa-solid fa-gas-pump"></i> Fuel &amp; Expenses
        </a>
        <a href="/analytics" class="nav-item">
          <i class="fa-solid fa-chart-line"></i> Analytics
        </a>
        <a href="/settings" class="nav-item">
          <i class="fa-solid fa-gear"></i> Settings
        </a>
      </nav>

      <div class="sidebar-footer">
        <button type="button" class="nav-item logout-btn" id="logoutBtn">
          <i class="fa-solid fa-right-from-bracket"></i> Logout
        </button>
      </div>
    </aside>

    <!-- Main -->
    <div class="dash-main">

      <header class="topbar">
        <div class="topbar-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search service log…" id="maintenanceSearch" />
        </div>

        <div class="topbar-right">
          <button class="icon-btn" title="Notifications">
            <i class="fa-regular fa-bell"></i>
          </button>
          <div class="user-block">
            <span class="user-name" id="userName">—</span>
            <span class="status-pill" id="connectionStatus">
              <span class="status-dot"></span> Connecting…
            </span>
          </div>
        </div>
      </header>

      <main class="dash-content">

        <div class="content-header content-header-row">
          <div>
            <h1>Maintenance</h1>
            <p class="page-subtitle">Review the service log first, then add a new maintenance record when needed.</p>
          </div>
          <button class="btn-primary" id="createMaintenanceBtn">
            <i class="fa-solid fa-plus"></i> New Service Log
          </button>
        </div>

        <section class="panel panel-log">
          <div class="panel-header">
            <h2>Service Logs</h2>
            <span class="panel-chip" id="maintenanceCountChip">Loading…</span>
          </div>
          <table class="trips-table">
            <thead>
              <tr>
                <th>Vehicle</th>
                <th>Service</th>
                <th>Cost</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="serviceLogBody">
              <tr class="table-loading-row">
                <td colspan="5">Loading service log…</td>
              </tr>
            </tbody>
          </table>
        </section>

        <p class="table-note">
          Available vehicles are loaded from the live API. Closing a service log returns the vehicle to available.
        </p>

      </main>
    </div>
  </div>

  <div class="modal-overlay" id="maintenanceModalOverlay">
    <div class="modal">
      <div class="modal-header">
        <h2 id="maintenanceModalTitle">Log Service Record</h2>
        <button class="icon-btn" id="closeMaintenanceModal" title="Close">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form id="maintenanceForm" class="modal-body maintenance-form">
        <div id="formError" class="form-error" hidden></div>

        <div class="form-group">
          <label for="vehicleSelect">Vehicle</label>
          <select id="vehicleSelect" required>
            <option value="">Loading vehicles…</option>
          </select>
        </div>

        <div class="form-group">
          <label for="serviceType">Service Type</label>
          <input type="text" id="serviceType" placeholder="e.g. Oil Change" required />
        </div>

        <div class="form-group">
          <label for="serviceCost">Cost</label>
          <input type="number" id="serviceCost" min="0" step="0.01" placeholder="e.g. 2500" required />
        </div>

        <div class="form-group">
          <label for="serviceDate">Date</label>
          <input type="date" id="serviceDate" required />
        </div>

        <div class="form-group">
          <label for="serviceStatus">Status</label>
          <select id="serviceStatus">
            <option value="open" selected>Open</option>
            <option value="completed">Completed</option>
          </select>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn-secondary" id="cancelMaintenanceModal">Cancel</button>
          <button type="submit" class="btn-save" id="saveBtn">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/auth-guard.js"></script>
  <script src="/js/maintenance.js"></script>
</body>
</html>