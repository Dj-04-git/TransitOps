<%- include('partials/head', { title: 'TransitOps | Vehicle Registry' }) %>

<body class="min-h-screen bg-base-200 text-base-content" data-theme="transitops-night">
  <div class="grid min-h-screen lg:grid-cols-[16rem_1fr]">
    <%- include('partials/sidebar', { active: 'fleet' }) %>

    <div class="flex min-h-screen flex-col">
      <%- include('partials/topbar', {
        userName: userName || 'Raven K.',
        userRole: userRole || 'Dispatcher',
        userInitials: userInitials || 'RK',
        query: query || ''
      }) %>

      <main class="flex-1 p-4 sm:p-6">
        <section class="rounded-[2rem] border border-base-300 bg-base-100/90 p-5 shadow-[0_24px_70px_rgba(0,0,0,0.35)] backdrop-blur sm:p-6">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <p class="text-sm uppercase tracking-[0.3em] text-base-content/45">2. Vehicle Registry</p>
              <h1 class="mt-2 text-3xl font-black tracking-tight sm:text-4xl">Vehicle Registry</h1>
              <p class="mt-3 max-w-3xl text-sm leading-7 text-base-content/60">
                Manage fleet assets with registration number, model, type, capacity, odometer, acquisition cost, and status.
              </p>
            </div>

            <div class="grid gap-3 sm:grid-cols-4 lg:min-w-[40rem]">
              <%- include('partials/summary-card', { label: 'Active Vehicles', value: summary && summary.activeVehicles != null ? summary.activeVehicles : '128' }) %>
              <%- include('partials/summary-card', { label: 'Available', value: summary && summary.availableVehicles != null ? summary.availableVehicles : '64' }) %>
              <%- include('partials/summary-card', { label: 'In Maintenance', value: summary && summary.inShopVehicles != null ? summary.inShopVehicles : '9' }) %>
              <%- include('partials/summary-card', { label: 'Retired', value: summary && summary.retiredVehicles != null ? summary.retiredVehicles : '4' }) %>
            </div>
          </div>

          <div class="mt-6">
            <%- include('partials/filter-row', {
              types: types || [],
              statuses: statuses || [],
              selectedType: selectedType || '',
              selectedStatus: selectedStatus || '',
              registrationQuery: registrationQuery || ''
            }) %>
          </div>

          <div class="mt-6 overflow-x-auto rounded-2xl border border-base-300 bg-base-100">
            <table class="table">
              <thead>
                <tr class="text-xs uppercase tracking-[0.25em] text-base-content/45">
                  <th>Reg. No.</th>
                  <th>Name/Model</th>
                  <th>Type</th>
                  <th>Capacity</th>
                  <th>Odometer</th>
                  <th>Acq. Cost</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% (vehicles || []).forEach((vehicle) => { %>
                  <tr class="border-base-300/70 hover:bg-base-200/60">
                    <td class="font-semibold"><%= vehicle.registrationNumber || vehicle.registrationNo || '-' %></td>
                    <td><%= vehicle.vehicleName || vehicle.name || vehicle.model || '-' %></td>
                    <td><%= vehicle.type || '-' %></td>
                    <td><%= vehicle.maximumLoadCapacity || vehicle.capacity || '-' %></td>
                    <td><%= vehicle.odometer || '-' %></td>
                    <td><%= vehicle.acquisitionCost || vehicle.acqCost || '-' %></td>
                    <td>
                      <%- include('partials/status-pill', {
                        label: vehicle.status || 'Available',
                        classes: vehicle.status === 'On Trip'
                          ? 'bg-info text-info-content'
                          : vehicle.status === 'In Shop'
                            ? 'bg-warning text-warning-content'
                            : vehicle.status === 'Retired'
                              ? 'bg-error text-error-content'
                              : 'bg-success text-success-content'
                      }) %>
                    </td>
                  </tr>
                <% }) %>

                <% if (!(vehicles && vehicles.length)) { %>
                  <tr>
                    <td colspan="7" class="py-12 text-center text-sm text-base-content/50">No vehicles to display. Render an array named <span class="font-semibold">vehicles</span> to show rows here.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>

          <p class="mt-4 text-sm text-warning">
            Rule: Registration No. must be unique. Retired/In Shop vehicles are hidden from the trip dispatcher.
          </p>
        </section>
      </main>
    </div>
  </div>

  <%- include('partials/vehicle-modal') %>
</body>
</html>