<%- include('partials/head', { title: 'Register · TransitOps' }) %>

<body class="min-h-screen bg-base-200 text-base-content">
  <main class="min-h-screen px-4 py-6 sm:px-6 lg:px-8">
    <div class="mx-auto grid min-h-[calc(100vh-3rem)] max-w-6xl overflow-hidden rounded-box border border-base-300 bg-base-100 lg:grid-cols-[0.95fr_1.05fr]">
      <section class="relative flex flex-col justify-between bg-neutral p-8 text-neutral-content lg:p-10">
        <div class="space-y-8">
          <div class="flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.28em] text-neutral-content/70">
            <span class="h-2 w-2 rounded-full bg-primary"></span>
            TransitOps
          </div>

          <div class="space-y-4">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-content/50">●──────── REGISTRATION</p>
            <h1 class="max-w-md text-4xl font-black tracking-tight sm:text-5xl">Create an operational account for your role.</h1>
            <p class="max-w-lg text-base leading-7 text-neutral-content/75">
              Register with your email, password, and role. The backend stores your account in PostgreSQL and returns a JWT-compatible identity profile.
            </p>
          </div>
        </div>

        <div class="grid gap-3 rounded-box border border-white/10 bg-white/5 p-4 text-sm text-neutral-content/80 sm:grid-cols-2">
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-neutral-content/50">Stored in database</p>
            <p class="mt-1 font-mono text-base text-neutral-content">users.email</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-neutral-content/50">Role required</p>
            <p class="mt-1 font-mono text-base text-neutral-content">fleet_manager / driver / safety_officer / financial_analyst</p>
          </div>
        </div>
      </section>

      <section class="flex items-center justify-center p-6 sm:p-8 lg:p-10">
        <div class="w-full max-w-xl">
          <div class="mb-8 space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-base-content/50">TransitOps / Auth</p>
            <h2 class="text-3xl font-black tracking-tight">Register</h2>
            <p class="text-sm leading-6 text-base-content/70">
              Enter your credentials and role. After registration, you will be sent to the login screen.
            </p>
          </div>

          <div id="registerAlert" class="alert mb-6 hidden"></div>

          <form id="registerForm" class="space-y-5" action="/api/auth/register" method="post">
            <label class="form-control w-full">
              <div class="label"><span class="label-text font-semibold">Email</span></div>
              <input id="email" name="email" type="email" class="input input-bordered w-full" placeholder="you@example.com" autocomplete="email" required />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-semibold">Password</span></div>
              <input id="password" name="password" type="password" class="input input-bordered w-full" placeholder="At least 6 characters" autocomplete="new-password" required />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-semibold">Role</span></div>
              <select id="role" name="role" class="select select-bordered w-full" required>
                <option value="" selected disabled>Select your role</option>
                <option value="fleet_manager">Fleet manager</option>
                <option value="driver">Driver</option>
                <option value="safety_officer">Safety officer</option>
                <option value="financial_analyst">Financial analyst</option>
              </select>
            </label>

            <button id="registerButton" type="submit" class="btn btn-primary w-full">Create account</button>
          </form>

          <div class="mt-6 border-t border-base-300 pt-5 text-sm text-base-content/70">
            Already have an account?
            <a class="link link-primary font-semibold" href="/login">Go to login</a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    const registerForm = document.getElementById('registerForm');
    const registerAlert = document.getElementById('registerAlert');
    const registerButton = document.getElementById('registerButton');

    const showAlert = (message, type) => {
      registerAlert.className = `alert mb-6 ${type === 'error' ? 'alert-error' : 'alert-success'}`;
      registerAlert.textContent = message;
      registerAlert.classList.remove('hidden');
    };

    registerForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      registerButton.disabled = true;
      registerButton.textContent = 'Creating account...';

      try {
        const payload = {
          email: registerForm.email.value.trim(),
          password: registerForm.password.value,
          role: registerForm.role.value
        };

        const response = await fetch('/api/auth/register', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Registration failed');
        }

        showAlert('Account created. Redirecting to login...', 'success');
        window.setTimeout(() => {
          window.location.href = '/login?registered=1';
        }, 700);
      } catch (error) {
        showAlert(error.message, 'error');
        registerButton.disabled = false;
        registerButton.textContent = 'Create account';
      }
    });
  </script>
</body>
</html>
