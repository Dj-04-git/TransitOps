<%- include('partials/head', { title: 'Register · TransitOps' }) %>

<body class="min-h-screen bg-base-200 text-base-content">
  <div class="flex min-h-screen flex-col">
    <%- include('partials/navbar', { active: '' }) %>

    <main class="flex flex-1 items-center">
      <div class="mx-auto w-full max-w-7xl px-6 py-12 lg:py-16">
        <div class="mb-8 flex items-center gap-3">
          <span class="h-2 w-2 rounded-full bg-primary"></span>
          <span class="h-px w-12 bg-primary"></span>

          <p class="font-mono text-xs font-semibold uppercase tracking-widest text-base-content/50">
            Auth / Account access
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-2 lg:gap-16">
          <!-- Intro -->
          <section class="flex flex-col justify-center">
            <p class="font-mono text-xs uppercase tracking-widest text-primary">
              TransitOps Control Network
            </p>

            <h1 class="mt-5 max-w-lg text-4xl font-black tracking-tight sm:text-5xl">
              Operations access for your fleet.
            </h1>

            <p class="mt-5 max-w-lg text-base leading-7 text-base-content/65">
              One control system for fleet assets, dispatch operations,
              driver compliance, and financial oversight.
            </p>

            <div class="mt-10 grid grid-cols-2 border-y border-base-300">
              <div class="border-b border-r border-base-300 p-5">
                <p class="font-mono text-xs text-primary">01</p>
                <p class="mt-2 text-sm font-semibold">Fleet</p>
                <p class="mt-1 text-xs text-base-content/50">
                  Assets & maintenance
                </p>
              </div>

              <div class="border-b border-base-300 p-5">
                <p class="font-mono text-xs text-primary">02</p>
                <p class="mt-2 text-sm font-semibold">Dispatch</p>
                <p class="mt-1 text-xs text-base-content/50">
                  Trips & assignments
                </p>
              </div>

              <div class="border-r border-base-300 p-5">
                <p class="font-mono text-xs text-primary">03</p>
                <p class="mt-2 text-sm font-semibold">Safety</p>
                <p class="mt-1 text-xs text-base-content/50">
                  Driver compliance
                </p>
              </div>

              <div class="p-5">
                <p class="font-mono text-xs text-primary">04</p>
                <p class="mt-2 text-sm font-semibold">Finance</p>
                <p class="mt-1 text-xs text-base-content/50">
                  Cost & profitability
                </p>
              </div>
            </div>

            <div class="mt-6 flex items-center gap-3">
              <span class="h-2 w-2 rounded-full bg-success"></span>

              <p class="font-mono text-xs uppercase tracking-widest text-base-content/45">
                RBAC / Operational access control active
              </p>
            </div>
          </section>

          <!-- Form -->
          <section class="flex items-center lg:justify-end">
            <div class="w-full max-w-lg border border-base-300 bg-base-100">
              <header class="border-b border-base-300 p-6 sm:p-8">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="font-mono text-xs uppercase tracking-widest text-base-content/45">
                      Account provisioning
                    </p>

                    <h2 class="mt-3 text-2xl font-black tracking-tight">
                      Create account
                    </h2>

                    <p class="mt-2 text-sm text-base-content/60">
                      Register credentials and assign an operational role.
                    </p>
                  </div>

                  <span class="badge badge-success badge-soft font-mono text-xs">
                    Online
                  </span>
                </div>
              </header>

              <form
                id="registerForm"
                action="/api/auth/register"
                method="post"
                class="space-y-5 p-6 sm:p-8"
              >
                <fieldset class="fieldset">
                  <legend class="fieldset-legend">
                    Email address
                  </legend>

                  <label class="input input-bordered flex w-full items-center gap-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 opacity-40"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                      />
                    </svg>

                    <input
                      id="email"
                      name="email"
                      type="email"
                      class="grow font-mono text-sm"
                      placeholder="operator@company.com"
                      autocomplete="email"
                      required
                    />
                  </label>
                </fieldset>

                <fieldset class="fieldset">
                  <legend class="fieldset-legend">
                    Password
                  </legend>

                  <label class="input input-bordered flex w-full items-center gap-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 opacity-40"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm2-10V7a4 4 0 118 0v4"
                      />
                    </svg>

                    <input
                      id="password"
                      name="password"
                      type="password"
                      class="grow font-mono text-sm"
                      placeholder="Minimum 6 characters"
                      minlength="6"
                      autocomplete="new-password"
                      required
                    />
                  </label>
                </fieldset>

                <fieldset class="fieldset">
                  <legend class="fieldset-legend">
                    Operational role
                  </legend>

                  <select
                    id="role"
                    name="role"
                    class="select select-bordered w-full"
                    required
                  >
                    <option value="" selected disabled>
                      Select account role
                    </option>

                    <option value="fleet_manager">
                      Fleet manager
                    </option>

                    <option value="driver">
                      Driver
                    </option>

                    <option value="safety_officer">
                      Safety officer
                    </option>

                    <option value="financial_analyst">
                      Financial analyst
                    </option>
                  </select>

                  <p class="fieldset-label">
                    Role determines accessible operational functions.
                  </p>
                </fieldset>

                <div
                  id="registerAlert"
                  class="alert hidden text-sm"
                  role="alert"
                ></div>

                <button
                  id="registerButton"
                  type="submit"
                  class="btn btn-primary w-full"
                >
                  Create account

                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="m9 18 6-6-6-6"
                    />
                  </svg>
                </button>
              </form>

              <footer class="flex items-center justify-between border-t border-base-300 bg-base-200 px-6 py-4 text-sm sm:px-8">
                <span class="text-base-content/55">
                  Existing account?
                </span>

                <a
                  href="/login"
                  class="link link-primary font-semibold"
                >
                  Sign in
                </a>
              </footer>
            </div>
          </section>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script>
    const registerForm = document.getElementById('registerForm');
    const registerAlert = document.getElementById('registerAlert');
    const registerButton = document.getElementById('registerButton');

    const showAlert = (message, type) => {
      registerAlert.className =
        `alert text-sm ${
          type === 'error'
            ? 'alert-error'
            : 'alert-success'
        }`;

      registerAlert.textContent = message;
      registerAlert.classList.remove('hidden');
    };

    registerForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      registerAlert.classList.add('hidden');
      registerButton.disabled = true;

      registerButton.innerHTML = `
        <span class="loading loading-spinner loading-sm"></span>
        Creating account
      `;

      try {
        const payload = {
          email: registerForm.email.value.trim(),
          password: registerForm.password.value,
          role: registerForm.role.value
        };

        const response = await fetch('/api/auth/register', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(
            data.error || 'Account registration failed.'
          );
        }

        showAlert(
          'Account created. Redirecting to login...',
          'success'
        );

        setTimeout(() => {
          window.location.href = '/login?registered=1';
        }, 700);
      } catch (error) {
        showAlert(error.message, 'error');

        registerButton.disabled = false;
        registerButton.textContent = 'Create account';
      }
    });
  </script>
</body>
</html>